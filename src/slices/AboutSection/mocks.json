			"text": {
				"__TYPE__": "StructuredTextContent",
				"value": [
					{
						"type": "paragraph",
						"content": {
							"text": "A Tecno System é uma Empresa Júnior inovadora do Cursos de Sistemas de Informação e Engenharia de Software da Universidade do Estado da Bahia – Campus II, situada em Alagoinhas - BA, atua no mercado de TI desde o ano de 2001 sendo gerida por alunos do curso. Instituição sem fins lucrativos, a Tecno System tem como objetivos principais capacitar seus membros através de cursos e projetos gerando assim aprendizado e preparando-os para o mercado de trabalho, além de promover serviços de qualidade que satisfaçam ao máximo seus clientes. ",
							"spans": []
						},
						"direction": "ltr"
					},
					{
						"type": "paragraph",
						"content": {
							"text": "Nossa missão é desenvolver soluções tecnológicas acessíveis e de qualidade, promovendo o crescimento de nossos clientes e a capacitação dos membros da empresa.  ",
							"spans": []
						},
						"direction": "ltr"
					}
				]
			}
